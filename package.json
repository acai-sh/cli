{
    "name": "@acai.sh/cli",
    "version": "0.0.3",
    "license": "Apache-2.0",
    "description": "CLI for syncing and querying acai.sh spec-driven development data.",
    "module": "index.ts",
    "type": "module",
    "homepage": "https://github.com/acai-sh/cli#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/acai-sh/cli.git"
    },
    "bugs": {
        "url": "https://github.com/acai-sh/cli/issues"
    },
    "keywords": [
        "acai",
        "cli",
        "spec-driven",
        "agent",
        "requirements"
    ],
    "files": [
        "dist",
        "README.md",
        "docs"
    ],
    "bin": {
        "acai": "dist/acai.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build:npm": "bun build ./src/index.ts --target=node --outfile dist/acai.js",
        "build:release:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64-modern --outfile dist/acai-linux-x64",
        "build:release:linux-arm64": "bun build ./src/index.ts --compile --target=bun-linux-arm64-modern --outfile dist/acai-linux-arm64",
        "build:release:darwin-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64-modern --outfile dist/acai-darwin-x64",
        "build:release:darwin-arm64": "bun build ./src/index.ts --compile --target=bun-darwin-arm64-modern --outfile dist/acai-darwin-arm64",
        "verify:npm-artifact": "node ./scripts/verify-npm-artifact.mjs",
        "prepack": "bun run build:npm",
        "test": "AGENT=1 bun test",
        "regen:openapi": "openapi-typescript api/openapi.json -o src/generated/openapi.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "openapi-typescript": "^7.13.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "commander": "^14.0.3",
        "openapi-fetch": "^0.17.0"
    }
}
